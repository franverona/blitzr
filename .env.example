# Your Chess.com username (case-insensitive). Required.
CHESSCOM_USERNAME=

# Defaults to "sqlite" if unset — no config needed for the common case.
# Only sqlite is implemented today; DB_TYPE is here so a future backend
# (e.g. postgres) can be added without changing the data-access layer's callers.
# DB_TYPE=sqlite

# UI language: "en" (default) or "es". Needs the NEXT_PUBLIC_ prefix so
# client components can read it too — restart/rebuild after changing it.
# NEXT_PUBLIC_LOCALE=en
